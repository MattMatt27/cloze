# LLM Chat Environment Configuration
# Copy this file to .env and add your API keys

# OpenAI API Key (optional)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key (optional)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google API Key (optional)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# Database URL (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///llm_chat.db

# Ollama Host (optional - defaults to localhost:11434)
# Set this if Ollama is running on a different server
# OLLAMA_HOST=http://localhost:11434

# Secret Key (optional - auto-generated if not provided)
# SECRET_KEY=
